{
  "name": "the-system",
  "version": "1.0.0",
  "private": true,
  "description": "THE SYSTEM — a Solo Leveling-style fitness RPG with a living body avatar, daily quests, penalties, and a Groq-powered AI coach.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbo -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "app:prepare": "node electron/prepare-standalone.mjs",
    "app:icon": "node electron/make-icon.mjs",
    "app:start": "electron .",
    "app:dist": "next build && npm run app:prepare && npm run app:icon && electron-builder --win"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.417.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  },
  "build": {
    "appId": "com.thesystem.hunterprotocol",
    "productName": "THE SYSTEM",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app-server"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "THE SYSTEM"
    },
    "portable": {
      "artifactName": "THE SYSTEM ${version} (Portable).exe"
    }
  }
}
